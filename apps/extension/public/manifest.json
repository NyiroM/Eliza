{
  "manifest_version": 3,
  "name": "ELIZA Copilot",
  "version": "1.0.0",
  "description": "AI-assisted job fit copilot for selected job descriptions.",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": ["http://localhost:3000/*", "<all_urls>"],
  "action": {
    "default_title": "ELIZA",
    "default_popup": "index.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
