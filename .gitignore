# See https://help.github.com/articles/ignoring-files/

# Dependencies
node_modules/
apps/extension/node_modules/

# Next.js
.next/
out/

# Extension build output (rebuild with `npm run build` in apps/extension)
apps/extension/dist/

# Production / caches
build/
.cache/
.turbo/
*.tsbuildinfo

# Local user data (CV, constraints, preferences — never commit root ./storage only)
/storage/

# Testing
coverage/

# Environment (commit .env.example; ignore real secrets)
.env*
!.env.example

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Vercel
.vercel

# Misc
.DS_Store
*.pem
Thumbs.db

# IDE
.vscode/
.idea/
.cursor/

# Package manager
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
