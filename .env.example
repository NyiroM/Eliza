# -----------------------------------------------------------------------------
# ELIZA environment (copy to .env.local and adjust; never commit real secrets)
# -----------------------------------------------------------------------------

# Base URL for the Ollama HTTP API (no trailing slash).
# Default if unset: http://localhost:11434
OLLAMA_HOST=http://localhost:11434

# -----------------------------------------------------------------------------
# Browser extension (apps/extension) — optional Vite variables
# -----------------------------------------------------------------------------
# VITE_ELIZA_API_URL=http://localhost:3000
