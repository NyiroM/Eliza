# -----------------------------------------------------------------------------
# ELIZA environment (copy to .env.local and adjust; never commit real secrets)
# -----------------------------------------------------------------------------
# API validation (code): job text length, PDF size/type, Ollama model tag pattern,
# preferred_location max length — see lib/validation.ts

# Base URL for the Ollama HTTP API (no trailing slash).
# Default if unset: http://127.0.0.1:11434
# Do not use 0.0.0.0 here — that is a bind address, not a valid client URL; use 127.0.0.1 or localhost.
OLLAMA_HOST=http://127.0.0.1:11434

# -----------------------------------------------------------------------------
# Browser extension (apps/extension) — optional Vite variables
# -----------------------------------------------------------------------------
# VITE_ELIZA_API_URL=http://localhost:3000
